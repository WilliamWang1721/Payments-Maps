OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=xiaomi/mimo-v2-omni
OPENROUTER_MODEL_PRIMARY=xiaomi/mimo-v2-omni
OPENROUTER_MODEL_ENV=development
OPENROUTER_ROTATE_FALLBACKS=true
OPENROUTER_DISCOVER_FREE_MODELS=true
