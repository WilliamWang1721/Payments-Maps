{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/mcp/:sessionToken",
      "destination": "/api/mcp/:sessionToken"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
